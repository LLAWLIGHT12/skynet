# 复制为 .env 并填入真实密钥（.env 已在 .gitignore 中）

FALLBACK_LLM_API_BASE_URL=https://api.deepseek.com/v1
FALLBACK_LLM_API_KEY=your-api-key-here
FALLBACK_LLM_MODEL_NAME=deepseek-chat
FALLBACK_LLM_TEMPERATURE=0.1
FALLBACK_LLM_MAX_TOKENS=20000
FALLBACK_LLM_TIMEOUT=60

