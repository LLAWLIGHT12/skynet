{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DedupeOutput",
  "description": "Clustered confirmed findings \u2014 one group per root cause.",
  "type": "object",
  "required": [
    "groups"
  ],
  "additionalProperties": true,
  "properties": {
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "group_id",
          "root_cause",
          "member_finding_ids",
          "canonical_finding_id"
        ],
        "additionalProperties": true,
        "properties": {
          "group_id": {
            "type": "string",
            "pattern": "^g_[a-z0-9_-]{1,64}$"
          },
          "root_cause": {
            "type": "string",
            "minLength": 20,
            "description": "The single underlying defect that explains every member finding."
          },
          "member_finding_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "canonical_finding_id": {
            "type": "string",
            "description": "Member id that best exemplifies the bug \u2014 usually the highest severity / clearest PoC."
          },
          "variant_summary": {
            "type": "string",
            "description": "Brief note on how members differ (different call sites, different inputs, etc.)."
          }
        }
      }
    }
  }
}
